rules_version = '2';
// ════════════════════════════════════════════════════════
// Firestore Security Rules — برجمان
// يجب رفع هذا الملف عبر Firebase Console أو CLI
// firebase deploy --only firestore:rules
// ════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── دوال مساعدة ───────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ─── المستخدمون: القراءة مفتوحة للمصادقين، الكتابة للمستخدم نفسه أو الأدمن ───
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && (request.auth.uid == userId || request.auth.token.admin == true);
    }

    // ─── الطلبات: القراءة والكتابة للمصادقين فقط ───────
    match /orders/{orderId} {
      allow read, write: if isAuth();
    }

    // ─── الإعدادات: القراءة عامة، الكتابة للأدمن فقط ───
    match /settings/{settingId} {
      // الإعدادات غير المحمية: قراءة عامة
      allow read: if resource.data.protected != true;
      // الإعدادات المحمية: قراءة للمصادقين فقط
      allow read: if isAuth() && resource.data.protected == true;
      // الكتابة: للمصادقين فقط (يجب إضافة فحص الدور بعد ترقية المصادقة)
      allow write: if isAuth();
    }

    // ─── المنتجات: قراءة عامة، كتابة للمصادقين ─────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ─── الإشعارات: للمصادقين فقط ───────────────────────
    match /notifications/{notifId} {
      allow read, write: if isAuth();
    }

    // ─── العروض والحملات: قراءة عامة ───────────────────
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /campaigns/{campId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ─── الباقي: للمصادقين فقط ──────────────────────────
    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}
